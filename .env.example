# ZeroBounce API key (standard). Get your key at https://www.zerobounce.net/docs/api-dashboard
# Copy this file to .env and set your key.
ZEROBOUNCE_API_KEY=your_api_key_here

# Optional: custom API URIs (defaults to production if unset)
# ZERO_BOUNCE_URI=
# ZERO_BOUNCE_BULK_URI=

# Legacy: ZERO_BOUNCE_API_KEY is still supported for backward compatibility.
